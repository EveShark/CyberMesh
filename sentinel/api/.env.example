# ===========================================
# SENTINEL API - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# Never commit .env to git!

# -------------------------------------------
# CLERK AUTHENTICATION (Required)
# -------------------------------------------
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# -------------------------------------------
# SUPABASE DATABASE (Required)
# -------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_secret_xxxxx
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx

# -------------------------------------------
# APP SETTINGS
# -------------------------------------------
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# -------------------------------------------
# FILE UPLOAD LIMITS
# -------------------------------------------
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=.exe,.dll,.pdf,.doc,.docx,.xls,.xlsx,.ps1,.bat,.js,.vbs,.sh,.py,.apk,.elf

# -------------------------------------------
# SCAN SETTINGS
# -------------------------------------------
SCAN_TIMEOUT_SECONDS=60
ENABLE_LLM=false
ENABLE_THREAT_INTEL=false

# -------------------------------------------
# SENTINEL PATHS
# -------------------------------------------
YARA_RULES_PATH=../rules
MALWARE_HASHES_PATH=../data/malware_hashes.json

# -------------------------------------------
# RATE LIMITING
# -------------------------------------------
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_HOUR=100

# -------------------------------------------
# OPTIONAL: STORAGE (Add when needed)
# -------------------------------------------
# S3_ENDPOINT=https://your-bucket.r2.cloudflarestorage.com
# S3_BUCKET=sentinel-uploads
# S3_ACCESS_KEY=xxxxx
# S3_SECRET_KEY=xxxxx

# -------------------------------------------
# OPTIONAL: REDIS CACHE (Add when needed)
# -------------------------------------------
# REDIS_URL=redis://localhost:6379

# -------------------------------------------
# OPTIONAL: ERROR TRACKING (Add when needed)
# -------------------------------------------
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
