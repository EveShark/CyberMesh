# ============================================================
# SENTINEL CONFIGURATION TEMPLATE
# ============================================================
# Copy this file to .env and fill in your values
# Generate secrets with: python -c "import secrets; print(secrets.token_hex(32))"
# DO NOT COMMIT .env TO GIT - it contains secrets
# ============================================================

# ============================================================
# 1. ENVIRONMENT SETTINGS
# ============================================================
ENVIRONMENT=development
NODE_ID=sentinel-1
SERVICE_NAME=sentinel

# ============================================================
# 2. SECURITY & CRYPTOGRAPHY
# ============================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ENCRYPTION_KEY=
SIGNING_KEY=

# ============================================================
# 3. LLM PROVIDERS
# ============================================================
# GLM-4 (Zhipu AI) - Primary LLM
# Get your API key from: https://open.bigmodel.cn/
GLM_API_KEY=
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-plus

# Qwen (Alibaba) - Fallback LLM
# Get your API key from: https://dashscope.aliyuncs.com/
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/api/v1
QWEN_MODEL=qwen-max

# Ollama (Local) - Privacy-focused fallback
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ============================================================
# 4. THREAT INTELLIGENCE APIs
# ============================================================
# VirusTotal - Get key from: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# AbuseIPDB - Get key from: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# CrowdSec CTI - Get key from: https://app.crowdsec.net/settings/api-keys
# Provides botnet behaviors, DDoS source detection, attack scenarios
CROWDSEC_API_KEY=

# Feodo Tracker - No API key needed (public feed)
# Tracks C2 servers for Emotet, Dridex, TrickBot, QakBot

# Spamhaus - No API key needed (DNS-based lookup)
# DROP lists, botnet detection, spam sources

# ============================================================
# 5. ML MODELS
# ============================================================
MODELS_PATH=./data/models
MODEL_REGISTRY_PATH=./data/models/model_registry.json

# Detection thresholds
MALWARE_THRESHOLD=0.85
FAST_PATH_THRESHOLD=0.95
UNCERTAIN_THRESHOLD=0.5
MIN_CONFIDENCE=0.70

# ============================================================
# 6. AGENT CONFIGURATION
# ============================================================
AGENT_TIMEOUT_SECONDS=30
MAX_AGENT_ITERATIONS=5
COORDINATOR_MODEL=glm-4-plus

# ============================================================
# 7. OUTPUT & REPORTS
# ============================================================
REPORT_OUTPUT_DIR=./reports

# ============================================================
# 8. LOGGING
# ============================================================
LOG_LEVEL=INFO
LOG_FORMAT=human

# ============================================================
# 9. YARA RULES
# ============================================================
YARA_RULES_PATH=./data/yara_rules

# ============================================================
# 10. HASH DATABASE
# ============================================================
MALWARE_HASHES_PATH=./data/malware_hashes.json
CLEAN_HASHES_PATH=./data/clean_hashes.json

# ============================================================
# END OF CONFIGURATION
# ============================================================
