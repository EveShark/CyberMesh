{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["schema", "ts", "tenant_id", "flow_id", "src_ip", "dst_ip", "src_port", "dst_port", "protocol"],
  "properties": {
    "schema": { "const": "cic.v1" },
    "ts": { "type": "integer", "description": "Unix timestamp (seconds)" },
    "tenant_id": { "type": "string", "minLength": 1 },
    "flow_id": { "type": "string", "minLength": 8 },
    "src_ip": {
      "type": "string",
      "oneOf": [
        { "format": "ipv4" },
        { "format": "ipv6" }
      ]
    },
    "dst_ip": {
      "type": "string",
      "oneOf": [
        { "format": "ipv4" },
        { "format": "ipv6" }
      ]
    },
    "src_port": { "type": "integer", "minimum": 0, "maximum": 65535 },
    "dst_port": { "type": "integer", "minimum": 0, "maximum": 65535 },
    "protocol": { "type": "integer" },
    "source_type": { "type": "string" },
    "source_id": { "type": "string" },
    "feature_mask": { "type": "string", "description": "Hex bitmask of available features" },
    "feature_coverage": { "type": "number", "minimum": 0.0, "maximum": 1.0, "description": "Ratio of available features" },
    "flow_duration": { "type": "number" },
    "tot_fwd_pkts": { "type": "number" },
    "tot_bwd_pkts": { "type": "number" },
    "totlen_fwd_pkts": { "type": "number" },
    "totlen_bwd_pkts": { "type": "number" },
    "fwd_pkt_len_max": { "type": "number" },
    "fwd_pkt_len_min": { "type": "number" },
    "fwd_pkt_len_mean": { "type": "number" },
    "fwd_pkt_len_std": { "type": "number" },
    "bwd_pkt_len_max": { "type": "number" },
    "bwd_pkt_len_min": { "type": "number" },
    "bwd_pkt_len_mean": { "type": "number" },
    "bwd_pkt_len_std": { "type": "number" },
    "flow_byts_s": { "type": "number" },
    "flow_pkts_s": { "type": "number" },
    "flow_iat_mean": { "type": "number" },
    "flow_iat_std": { "type": "number" },
    "flow_iat_max": { "type": "number" },
    "flow_iat_min": { "type": "number" },
    "fwd_iat_tot": { "type": "number" },
    "fwd_iat_mean": { "type": "number" },
    "fwd_iat_std": { "type": "number" },
    "fwd_iat_max": { "type": "number" },
    "fwd_iat_min": { "type": "number" },
    "bwd_iat_tot": { "type": "number" },
    "bwd_iat_mean": { "type": "number" },
    "bwd_iat_std": { "type": "number" },
    "bwd_iat_max": { "type": "number" },
    "bwd_iat_min": { "type": "number" },
    "fwd_psh_flags": { "type": "number" },
    "bwd_psh_flags": { "type": "number" },
    "fwd_urg_flags": { "type": "number" },
    "bwd_urg_flags": { "type": "number" },
    "fwd_header_len": { "type": "number" },
    "bwd_header_len": { "type": "number" },
    "fwd_pkts_s": { "type": "number" },
    "bwd_pkts_s": { "type": "number" },
    "pkt_len_min": { "type": "number" },
    "pkt_len_max": { "type": "number" },
    "pkt_len_mean": { "type": "number" },
    "pkt_len_std": { "type": "number" },
    "pkt_len_var": { "type": "number" },
    "fin_flag_cnt": { "type": "number" },
    "syn_flag_cnt": { "type": "number" },
    "rst_flag_cnt": { "type": "number" },
    "psh_flag_cnt": { "type": "number" },
    "ack_flag_cnt": { "type": "number" },
    "urg_flag_cnt": { "type": "number" },
    "cwe_flag_count": { "type": "number" },
    "ece_flag_cnt": { "type": "number" },
    "down_up_ratio": { "type": "number" },
    "pkt_size_avg": { "type": "number" },
    "fwd_seg_size_avg": { "type": "number" },
    "bwd_seg_size_avg": { "type": "number" },
    "fwd_byts_b_avg": { "type": "number" },
    "fwd_pkts_b_avg": { "type": "number" },
    "fwd_blk_rate_avg": { "type": "number" },
    "bwd_byts_b_avg": { "type": "number" },
    "bwd_pkts_b_avg": { "type": "number" },
    "bwd_blk_rate_avg": { "type": "number" },
    "subflow_fwd_pkts": { "type": "number" },
    "subflow_fwd_byts": { "type": "number" },
    "subflow_bwd_pkts": { "type": "number" },
    "subflow_bwd_byts": { "type": "number" },
    "init_fwd_win_byts": { "type": "number" },
    "init_bwd_win_byts": { "type": "number" },
    "fwd_act_data_pkts": { "type": "number" },
    "fwd_seg_size_min": { "type": "number" },
    "active_mean": { "type": "number" },
    "active_std": { "type": "number" },
    "active_max": { "type": "number" },
    "active_min": { "type": "number" },
    "idle_mean": { "type": "number" },
    "idle_std": { "type": "number" },
    "idle_max": { "type": "number" },
    "idle_min": { "type": "number" }
  }
}
